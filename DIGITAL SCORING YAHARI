<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
    import { getDatabase, ref, set, onValue, update } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js";

    const firebaseConfig = {
  apiKey: "AIzaSyCcZavbq10yi5FlaVbiRyWu9UgtRktnWvo",
  authDomain: "digital-scoring-ms-club.firebaseapp.com",
  databaseURL: "https://digital-scoring-ms-club-default-rtdb.asia-southeast1.firebasedatabase.app",
  projectId: "digital-scoring-ms-club",
  storageBucket: "digital-scoring-ms-club.firebasestorage.app",
  messagingSenderId: "509771210450",
  appId: "1:509771210450:web:02732892127373e439570b"
};

    const app = initializeApp(firebaseConfig);
    const database = getDatabase(app);
    const dbRef = ref(database, 'pencak_scoring_state');

    const INITIAL_STATE = {
        timer: 120, babak: 1, isRunning: false, idx: 0, bertandingIdx: -1, persiapanIdx: -1,
        matches: Array.from({length: 100}, (_, i) => ({ 
            p: i+1, m: "", b: "", km: "", kb: "", cat: "USIA DINI", kelas: "A", gender: "PUTRA", fase: "PENYISIHAN", status: 'idle', totalM: 0, totalB: 0, winner: "",
            maxBabak: 3, maxTimer: 120
        })),
        merah: { juri: {j1:[0,0,0], j2:[0,0,0], j3:[0,0,0]}, penHistory: [], jat: 0, history: {j1:[], j2:[], j3:[]}, dis: false },
        biru: { juri: {j1:[0,0,0], j2:[0,0,0], j3:[0,0,0]}, penHistory: [], jat: 0, history: {j1:[], j2:[], j3:[]}, dis: false },
        buffer: {
            merah: { v1: {j1:0, j2:0, j3:0}, v2: {j1:0, j2:0, j3:0} },
            biru: { v1: {j1:0, j2:0, j3:0}, v2: {j1:0, j2:0, j3:0} }
        },
        juriNames: { j1: "JURI 1", j2: "JURI 2", j3: "JURI 3" },
        var: { active: false, type: '', votes: { j1: '', j2: '', j3: '' } },
        lastHit: { juri: 0, sudut: '', time: 0 }
    };

    window.state = INITIAL_STATE;
    window.localJuri = localStorage.getItem('pencak_role_juri') || 0;
    let tInt = null;
    window.sekrePage = 0;

    onValue(dbRef, (snapshot) => {
        const data = snapshot.val();
        if (data) {
            window.state = data;
            updateUI();
        } else {
            set(dbRef, INITIAL_STATE);
        }
    });

    window.broadcast = function(path = "", value = null) {
        if (path !== "") {
            const specificRef = ref(database, 'pencak_scoring_state/' + path);
            set(specificRef, value);
        } else {
            set(dbRef, window.state);
        }
    }

    window.changeScreen = function(id) { 
        document.querySelectorAll('.screen').forEach(s => s.classList.remove('active')); 
        document.getElementById('screen-'+id).classList.add('active'); 
        if(id === 'sekretaris') renderSekreForm();
        if(id === 'operator') renderOperatorTable();
        if(id === 'jadwal') renderJadwalTable();
    }

    window.updateUI = function() {
        const isMonitor = document.getElementById('screen-monitor').classList.contains('active');
        const m = window.state.matches[window.state.idx];
        const mb = window.state.bertandingIdx >= 0 ? window.state.matches[window.state.bertandingIdx] : m;
        const tStr = (s) => `${Math.floor(s/60).toString().padStart(2,'0')}:${((s||0)%60).toString().padStart(2,'0')}`;
        
        const timerEls = ['dw-timer-disp', 'mon-timer-disp', 'jr-timer-disp'];
        timerEls.forEach(id => {
            const el = document.getElementById(id);
            if(el) el.innerText = tStr(window.state.timer);
        });

        const babakEls = ['dw-babak-disp', 'mon-babak-disp'];
        babakEls.forEach(id => {
            const el = document.getElementById(id);
            if(el) el.innerText = "BABAK " + window.state.babak;
        });

        [1,2,3].forEach(b => {
            const btn = document.getElementById(`dw-btn-b${b}`);
            if(btn) btn.classList.toggle('active-babak', window.state.babak === b);
        });

        const detailStr = (p) => {
            if(!p.m && !p.b) return "BELUM ADA DATA PERTANDINGAN";
            return `PARTAI ${p.p} / ${p.fase} ${p.cat} ${p.kelas} ${p.gender} / <span class="text-red-600">${p.m} (${p.km})</span> VS <span class="text-blue-600">${p.b} (${p.kb})</span>`;
        };

        if(document.getElementById('cur-match-detail')) document.getElementById('cur-match-detail').innerHTML = detailStr(mb);
        if(document.getElementById('mon-cur-match-detail')) document.getElementById('mon-cur-match-detail').innerHTML = detailStr(mb);
        
        const pMatch = window.state.persiapanIdx >= 0 ? window.state.matches[window.state.persiapanIdx] : {m:"", b:"", p:"--"};
        const pInfo = pMatch.m || pMatch.b ? detailStr(pMatch) : "BELUM ADA DATA PERTANDINGAN";
        if(document.getElementById('pers-match-detail')) document.getElementById('pers-match-detail').innerHTML = pInfo;
        if(document.getElementById('mon-pers-match-detail')) document.getElementById('mon-pers-match-detail').innerHTML = pInfo;

        const statusConfigs = [
            { id: 'dw-header-tanding', active: window.state.bertandingIdx !== -1, class: 'status-header-active-tanding' },
            { id: 'dw-header-persiapan', active: window.state.persiapanIdx !== -1, class: 'status-header-active-persiapan' },
            { id: 'mon-header-tanding', active: window.state.bertandingIdx !== -1, class: 'status-header-active-tanding' },
            { id: 'mon-header-persiapan', active: window.state.persiapanIdx !== -1, class: 'status-header-active-persiapan' }
        ];
        statusConfigs.forEach(conf => {
            const el = document.getElementById(conf.id);
            if(el) el.classList.toggle(conf.class, conf.active);
        });

        let tm = calculateTotal('merah'), tb = calculateTotal('biru');
        
        const applyGlow = (pre) => {
            const bBox = document.getElementById(`${pre}-box-b`);
            const mBox = document.getElementById(`${pre}-box-m`);
            if(bBox && mBox) {
                bBox.classList.remove('leader-glow');
                mBox.classList.remove('leader-glow');
                if(tb > tm && tb > 0) bBox.classList.add('leader-glow');
                else if(tm > tb && tm > 0) mBox.classList.add('leader-glow');
            }
        };
        
        const syncParticipants = (pre) => {
            if(document.getElementById(`${pre}-b-nama`)) document.getElementById(`${pre}-b-nama`).innerText = mb.b || 'BIRU';
            if(document.getElementById(`${pre}-b-kont`)) document.getElementById(`${pre}-b-kont`).innerText = mb.kb || '---';
            if(document.getElementById(`${pre}-total-b`)) document.getElementById(`${pre}-total-b`).innerText = tb === -999 ? "DIS" : tb;
            
            if(document.getElementById(`${pre}-m-nama`)) document.getElementById(`${pre}-m-nama`).innerText = mb.m || 'MERAH';
            if(document.getElementById(`${pre}-m-kont`)) document.getElementById(`${pre}-m-kont`).innerText = mb.km || '---';
            if(document.getElementById(`${pre}-total-m`)) document.getElementById(`${pre}-total-m`).innerText = tm === -999 ? "DIS" : tm;
            applyGlow(pre);
        };
        syncParticipants('dw'); syncParticipants('mon');

        const rP = (s) => { const h = window.state[s].penHistory || []; return `B:${h.filter(x=>x.type.startsWith('binaan')).length}|T:${h.filter(x=>x.type.startsWith('teguran')).length}|P:${h.filter(x=>x.type.startsWith('peringatan')).length}`; };
        
        const rPFull = (s) => {
            const h = window.state[s].penHistory || [];
            if (h.length === 0) return "TIDAK ADA PELANGGARAN";
            const map = { binaan1:"Binaan 1", binaan2:"Binaan 2", teguran1:"Teguran 1", teguran2:"Teguran 2", peringatan1:"Peringatan 1", peringatan2:"Peringatan 2" };
            return h.map(x => map[x.type]).join(", ");
        };

        if(document.getElementById('dw-pen-sum-m')) document.getElementById('dw-pen-sum-m').innerText = rP('merah');
        if(document.getElementById('dw-pen-sum-b')) document.getElementById('dw-pen-sum-b').innerText = rP('biru');
        if(document.getElementById('mon-pen-full-m')) document.getElementById('mon-pen-full-m').innerText = rPFull('merah');
        if(document.getElementById('mon-pen-full-b')) document.getElementById('mon-pen-full-b').innerText = rPFull('biru');

        const buildTable = () => {
            let html = "";
            ['biru','merah'].forEach(side => {
                const sc = window.state[side];
                const name = side==='biru' ? (mb.b||'BIRU') : (mb.m||'MERAH');
                const kont = side==='biru' ? (mb.kb||'-') : (mb.km||'-');
                const total = calculateTotal(side);
                html += `<tr><td class="text-left font-bold ${side==='biru'?'text-blue-600':'text-red-600'} px-1 leading-tight">${name}<br><span class="text-[5px] text-slate-400 font-bold">${kont}</span></td>`;
                [1,2,3].forEach(j => {
                    [0,1,2].forEach(b => {
                        const val = sc.juri['j'+j][b];
                        const isNew = window.state.lastHit.juri === j && window.state.lastHit.sudut === side && (Date.now() - window.state.lastHit.time < 1000);
                        html += `<td class="${isNew ? 'cell-active' : ''}">${val}</td>`;
                    });
                });
                html += `<td class="${side==='biru'?'bg-blue-50':'bg-red-50'} font-black text-[10px]">${total===-999?'DIS':total}</td></tr>`;
            });
            return html;
        };
        if(document.getElementById('dw-rt-table')) document.getElementById('dw-rt-table').innerHTML = buildTable();
        if(document.getElementById('mon-rt-table')) document.getElementById('mon-rt-table').innerHTML = buildTable();

        if(window.localJuri) {
            document.getElementById('jr-role-name').innerText = window.state.juriNames['j'+window.localJuri];
            document.getElementById('jr-match-no').innerText = mb.p;
            document.getElementById('jr-b-nama-full').innerText = mb.b || "BIRU";
            document.getElementById('jr-m-nama-full').innerText = mb.m || "MERAH";

            const overlay = document.getElementById('jr-var-overlay');
            if (window.state.var.active) {
                overlay.classList.add('active');
                document.getElementById('jr-var-notif').innerText = `Juri ${window.localJuri} silakan beri pilihan untuk verifikasi ${window.state.var.type}`;
                const myVote = window.state.var.votes['j' + window.localJuri];
                ['biru', 'merah', 'kuning'].forEach(v => {
                    const btn = document.getElementById(`jr-vote-${v}`);
                    if(btn) btn.classList.toggle('circle-active', myVote === v);
                });
            } else { overlay.classList.remove('active'); }
        }

        const dwVarResultModal = document.getElementById('modal-dw-var-result');
        if(window.state.var.active && dwVarResultModal && !isMonitor) {
            dwVarResultModal.classList.add('active');
            ['j1', 'j2', 'j3'].forEach((j, i) => {
                const v = window.state.var.votes[j];
                const el = document.getElementById(`dw-vote-${i+1}`);
                if(el) {
                    el.className = "circle-vote " + (v === 'biru' ? 'circle-blue' : v === 'merah' ? 'circle-red' : v === 'kuning' ? 'circle-yellow' : 'circle-none');
                    if(v) el.classList.add('circle-active');
                    el.innerText = v ? '' : i+1;
                    if(v) el.innerHTML = '<i class="fas fa-check"></i>';
                }
            });
        } else if(dwVarResultModal) {
            dwVarResultModal.classList.remove('active');
        }

        syncPenaltyVisuals('merah'); syncPenaltyVisuals('biru');
        if(document.getElementById('screen-operator').classList.contains('active')) renderOperatorTable();
    }

    window.calculateTotal = function(s) {
        const sc = window.state[s]; if(sc.dis) return -999;
        const totJuri = (sc.juri.j1.reduce((a,b)=>a+b,0)) + (sc.juri.j2.reduce((a,b)=>a+b,0)) + (sc.juri.j3.reduce((a,b)=>a+b,0));
        const pMap = { teguran1:1, teguran2:2, peringatan1:5, peringatan2:10 };
        let tp = 0; (sc.penHistory || []).forEach(i => tp += (pMap[i.type]||0));
        return totJuri + sc.jat - tp;
    }

    window.initJuri = function(n) {
        window.localJuri = n;
        localStorage.setItem('pencak_role_juri', n);
        changeScreen('juri');
    }

    window.sendHitDirect = function(s, v) {
        if(!window.state.isRunning) return;
        const now = Date.now();
        const jKey = 'j' + window.localJuri;
        const bIdx = window.state.babak - 1;
        const vKey = 'v' + v;

        window.broadcast(`buffer/${s}/${vKey}/${jKey}`, now);

        const hits = window.state.buffer[s][vKey];
        const otherJuries = Object.keys(hits).filter(k => k !== jKey);
        let confirmed = false;

        otherJuries.forEach(otherKey => {
            if (hits[otherKey] > 0 && (now - hits[otherKey]) <= 2000) {
                confirmed = true;
                const currentScoreOther = window.state[s].juri[otherKey][bIdx];
                window.broadcast(`${s}/juri/${otherKey}/${bIdx}`, currentScoreOther + v);
                window.broadcast(`buffer/${s}/${vKey}/${otherKey}`, 0);
            }
        });

        if (confirmed) {
            const currentScoreSelf = window.state[s].juri[jKey][bIdx];
            window.broadcast(`${s}/juri/${jKey}/${bIdx}`, currentScoreSelf + v);
            
            const snd = document.getElementById('snd-hit');
            if(snd) { snd.currentTime = 0; snd.play(); }
            window.broadcast(`lastHit`, { juri: parseInt(window.localJuri), sudut: s, time: now });
            window.broadcast(`buffer/${s}/${vKey}/${jKey}`, 0);
        }

        const newHistory = [...(window.state[s].history[jKey] || []), v];
        window.broadcast(`${s}/history/${jKey}`, newHistory);
    }

    window.undoLastHit = function(s) {
        if(!window.state.isRunning) return;
        const jKey = 'j' + window.localJuri;
        const bIdx = window.state.babak - 1;
        let h = window.state[s].history[jKey] || [];
        if(h.length > 0) {
            let lastVal = h.pop();
            let newScore = Math.max(0, window.state[s].juri[jKey][bIdx] - lastVal);
            window.broadcast(`${s}/juri/${jKey}/${bIdx}`, newScore);
            window.broadcast(`${s}/history/${jKey}`, h);
        }
    }

    window.timerCtrl = function(cmd) {
        if(cmd === 'start') {
            window.broadcast('isRunning', true);
            startTimerLogic();
        } else if(cmd === 'stop') {
            window.broadcast('isRunning', false);
            if(tInt) clearInterval(tInt);
        } else if(cmd === 'reset') {
            window.broadcast('isRunning', false);
            const m = window.state.matches[window.state.idx];
            window.broadcast('timer', m.maxTimer || 120);
        }
    }

    function startTimerLogic() {
        if(tInt) clearInterval(tInt);
        tInt = setInterval(() => {
            if(window.state.isRunning && window.state.timer > 0 && document.getElementById('screen-dewan').classList.contains('active')) {
                window.broadcast('timer', window.state.timer - 1);
            } else if(window.state.timer <= 0) {
                clearInterval(tInt);
                window.broadcast('isRunning', false);
            }
        }, 1000);
    }

    window.setRound = function(n) { 
        if(!window.state.isRunning) window.broadcast('babak', n); 
    }

    window.addJatuhan = function(s) { 
        window.broadcast(`${s}/jat`, window.state[s].jat + 3); 
    }

    window.sendVarVote = function(c) {
        if(window.localJuri) {
            window.broadcast(`var/votes/j${window.localJuri}`, c);
        }
    }

    window.startVAR = function(t) { 
        const varUpdate = { active: true, type: t, votes: { j1: '', j2: '', j3: '' } }; 
        window.broadcast('var', varUpdate);
        closeModal('modal-var-type'); 
    }

    window.closeVAR = function() { 
        window.broadcast('var/active', false); 
    }

    window.applyPenalty = function(s, p) { 
        const currentPen = [...(window.state[s].penHistory || [])];
        const idx = currentPen.findIndex(x => x.type === p && x.round === window.state.babak); 
        (idx > -1) ? currentPen.splice(idx, 1) : currentPen.push({ type: p, round: window.state.babak }); 
        window.broadcast(`${s}/penHistory`, currentPen);
    }

    function syncPenaltyVisuals(s) { 
        const pr = s === 'merah' ? 'm-' : 'b-'; 
        const history = window.state[s].penHistory || [];
        ['binaan1', 'binaan2', 'teguran1', 'teguran2', 'peringatan1', 'peringatan2'].forEach(t => { 
            const b = document.getElementById(pr + t); 
            if(b) b.classList.toggle('btn-pressed', history.some(p => p.type === t && p.round === window.state.babak)); 
        }); 
    }

    window.renderSekreForm = function() {
        const cont = document.getElementById('sekre-form-container');
        const start = window.sekrePage * 10;
        cont.innerHTML = window.state.matches.slice(start, start + 10).map((m, idx) => {
            const i = start + idx;
            return `<div class="p-3 bg-white rounded-xl border border-slate-200 shadow-sm">
                <div class="grid grid-cols-6 gap-1 mb-2">
                    <div class="text-center font-black text-[10px]">P.${m.p}</div>
                    <select id="in-f-${i}" class="input-sekre border border-slate-200"><option ${m.fase==='PENYISIHAN'?'selected':''}>PENYISIHAN</option><option ${m.fase==='PEREMPAT FINAL'?'selected':''}>PEREMPAT FINAL</option><option ${m.fase==='SEMI FINAL'?'selected':''}>SEMI FINAL</option><option ${m.fase==='FINAL'?'selected':''}>FINAL</option></select>
                    <select id="in-c-${i}" class="input-sekre border border-slate-200"><option ${m.cat==='USIA DINI'?'selected':''}>USIA DINI</option><option ${m.cat==='PRA REMAJA'?'selected':''}>PRA REMAJA</option><option ${m.cat==='REMAJA'?'selected':''}>REMAJA</option><option ${m.cat==='DEWASA'?'selected':''}>DEWASA</option></select>
                    <select id="in-k-${i}" class="input-sekre border border-slate-200">${['A','B','C','D','E','F','G','H','I','J','BEBAS'].map(k => `<option ${m.kelas===k?'selected':''}>${k}</option>`).join('')}</select>
                    <select id="in-g-${i}" class="input-sekre border border-slate-200"><option ${m.gender==='PUTRA'?'selected':''}>PUTRA</option><option ${m.gender==='PUTRI'?'selected':''}>PUTRI</option></select>
                    <select id="in-b-${i}" class="input-sekre border border-slate-200"><option value="1" ${m.maxBabak==1?'selected':''}>1 B</option><option value="2" ${m.maxBabak==2?'selected':''}>2 B</option><option value="3" ${m.maxBabak==3?'selected':''}>3 B</option></select>
                </div>
                <div class="grid grid-cols-2 gap-2 mb-2">
                    <div class="space-y-1 bg-red-100 p-1.5 rounded"><input id="in-mn-${i}" value="${m.m}" placeholder="NAMA MERAH" class="input-sekre bg-red-500 text-white placeholder-red-200"><input id="in-mk-${i}" value="${m.km}" placeholder="KONTINGEN MERAH" class="input-sekre bg-red-600 text-white placeholder-red-200"></div>
                    <div class="space-y-1 bg-blue-100 p-1.5 rounded"><input id="in-bn-${i}" value="${m.b}" placeholder="NAMA BIRU" class="input-sekre bg-blue-500 text-white placeholder-blue-200"><input id="in-bk-${i}" value="${m.kb}" placeholder="KONTINGEN BIRU" class="input-sekre bg-blue-600 text-white placeholder-blue-200"></div>
                </div>
                <div class="flex gap-2 items-center"><label class="text-[7px] font-bold">TIMER:</label><select id="in-t-${i}" class="input-sekre w-24 border border-slate-200"><option value="60" ${m.maxTimer==60?'selected':''}>1 MENIT</option><option value="90" ${m.maxTimer==90?'selected':''}>1.5 MENIT</option><option value="120" ${m.maxTimer==120?'selected':''}>2 MENIT</option><option value="180" ${m.maxTimer==180?'selected':''}>3 MENIT</option></select></div>
            </div>`;
        }).join('');
        document.getElementById('sekre-page-info').innerText = `Hal ${window.sekrePage + 1} / 10`;
    }

    window.saveSekreData = function() {
        const start = window.sekrePage * 10;
        const updatedMatches = [...window.state.matches];
        for(let i=start; i<start+10; i++) {
            const m = updatedMatches[i];
            m.fase = document.getElementById(`in-f-${i}`).value;
            m.cat = document.getElementById(`in-c-${i}`).value;
            m.kelas = document.getElementById(`in-k-${i}`).value;
            m.gender = document.getElementById(`in-g-${i}`).value;
            m.maxBabak = parseInt(document.getElementById(`in-b-${i}`).value);
            m.maxTimer = parseInt(document.getElementById(`in-t-${i}`).value);
            m.m = document.getElementById(`in-mn-${i}`).value;
            m.km = document.getElementById(`in-mk-${i}`).value;
            m.b = document.getElementById(`in-bn-${i}`).value;
            m.kb = document.getElementById(`in-bk-${i}`).value;
        }
        window.broadcast('matches', updatedMatches);
        showNotif();
    }

    window.renderOperatorTable = function() {
        const body = document.getElementById('operator-table-body');
        body.innerHTML = window.state.matches.filter(m => m.m || m.b).map((m, i) => {
            const isBertanding = window.state.bertandingIdx === m.p-1;
            const isPersiapan = window.state.persiapanIdx === m.p-1;
            const isSelesai = m.status === 'selesai';
            return `<tr class="border-b"><td class="p-2">${i+1}</td><td class="p-2">PARTAI ${m.p}</td><td class="p-2 leading-tight"><span class="text-red-600">${m.m}</span> vs <span class="text-blue-600">${m.b}</span></td><td class="p-2 flex gap-1 justify-center"><button onclick="setMatchStatus(${m.p-1}, 'bertanding')" class="op-btn ${isBertanding ? 'btn-bertanding' : 'btn-inactive'}">Tanding</button><button onclick="setMatchStatus(${m.p-1}, 'persiapan')" class="op-btn ${isPersiapan ? 'btn-persiapan' : 'btn-inactive'}">Siap</button><button onclick="setMatchStatus(${m.p-1}, 'selesai')" class="op-btn ${isSelesai ? 'btn-selesai' : 'btn-inactive'}">Finish</button></td><td class="p-2">${m.winner || '-'}</td><td class="p-2"><button onclick="deleteMatch(${m.p-1})" class="text-red-400"><i class="fas fa-trash"></i></button></td></tr>`;
        }).join('');
    }

    window.setMatchStatus = function(idx, status) {
        if(status === 'bertanding') {
            if(window.state.bertandingIdx === idx) window.broadcast('bertandingIdx', -1);
            else { window.broadcast('bertandingIdx', idx); window.broadcast('idx', idx); resetActiveMatchData(); window.broadcast('timer', window.state.matches[idx].maxTimer); }
        } else if(status === 'persiapan') { window.broadcast('persiapanIdx', (window.state.persiapanIdx === idx) ? -1 : idx);
        } else if(status === 'selesai') {
            const m = {...window.state.matches[idx]}; m.status = 'selesai';
            m.totalM = calculateTotal('merah'); m.totalB = calculateTotal('biru');
            if (m.totalM > m.totalB) m.winner = m.m; else if (m.totalB > m.totalM) m.winner = m.b; else m.winner = "SERI";
            window.broadcast(`matches/${idx}`, m);
            if(window.state.bertandingIdx === idx) window.broadcast('bertandingIdx', -1);
        }
    }

    window.renderJadwalTable = function() {
        const body = document.getElementById('jadwal-table-body');
        body.innerHTML = window.state.matches.filter(m => m.m || m.b).map((m, i) => `<tr class="border-b"><td class="p-3 border">${i+1}</td><td class="p-3 border">Partai ${m.p}</td><td class="p-3 border text-[7.5px] uppercase leading-tight">${m.fase}<br>${m.cat} ${m.kelas} ${m.gender}</td><td class="p-3 border bg-blue-500 text-white leading-tight"><span>${m.b || '-'}</span><br><span class="text-[7px] opacity-80">(${m.kb || '-'})</span></td><td class="p-3 border bg-red-500 text-white leading-tight"><span>${m.m || '-'}</span><br><span class="text-[7px] opacity-80">(${m.km || '-'})</span></td></tr>`).join('');
    }

    function resetActiveMatchData() {
        window.broadcast('babak', 1);
        window.broadcast('isRunning', false);
        window.broadcast('merah', { juri:{j1:[0,0,0], j2:[0,0,0], j3:[0,0,0]}, penHistory:[], jat:0, history:{j1:[], j2:[], j3:[]}, dis:false });
        window.broadcast('biru', { juri:{j1:[0,0,0], j2:[0,0,0], j3:[0,0,0]}, penHistory:[], jat:0, history:{j1:[], j2:[], j3:[]}, dis:false });
        window.broadcast('buffer', INITIAL_STATE.buffer);
        window.broadcast('var', { active: false, type: '', votes: { j1: '', j2: '', j3: '' } });
    }

    window.finishMatch = function() { if(confirm("Selesaikan partai ini?")) setMatchStatus(window.state.idx, 'selesai'); }
    window.nextMatch = function() { if(window.state.idx < 99) { const next = window.state.idx + 1; setMatchStatus(next, 'bertanding'); } }
    window.executeDis = function(s) { window.broadcast(`${s}/dis`, true); closeModal('modal-diskualifikasi'); }
    window.openModal = function(id) { document.getElementById(id).classList.add('active'); }
    window.closeModal = function(id) { document.getElementById(id).classList.remove('active'); }
    window.showNotif = function() { const n = document.getElementById('save-ani'); n.classList.add('show'); setTimeout(()=>n.classList.remove('show'), 2000); }
    window.deleteMatch = function(idx) { if(confirm("Hapus data partai?")) { window.broadcast(`matches/${idx}`, INITIAL_STATE.matches[idx]); } }
    window.changeSekrePage = function(v) { let n = window.sekrePage + v; if(n >= 0 && n < 10) { window.sekrePage = n; renderSekreForm(); } }
    
    window.resetSystem = function() {
        if(confirm("Hapus seluruh data di Firebase?")) {
            window.broadcast("", INITIAL_STATE);
            setTimeout(() => location.reload(), 1000);
        }
    }

    window.exportCSV = function() {
        let csv = "No,Partai,Kelas,Sudut Biru,Sudut Merah,Skor B,Skor M,Pemenang\n";
        window.state.matches.filter(m => m.m || m.b).forEach(m => { csv += `${m.p},${m.fase},${m.cat} ${m.kelas},${m.b},${m.m},${m.totalB},${m.totalM},${m.winner}\n`; });
        const blob = new Blob([csv], { type: 'text/csv' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a'); a.href = url; a.download = 'hasil_pertandingan.csv'; a.click();
    }
</script>
</body>
</html>
