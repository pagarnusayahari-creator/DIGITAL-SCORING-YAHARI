                    <button onclick="undoLastHit('merah')" class="w-10 h-10 bg-yellow-400 text-black rounded-xl flex items-center justify-center shadow-md active:scale-90"><i class="fas fa-delete-left text-sm"></i></button>
                </div>
                <div class="flex-1 flex flex-col gap-3">
                    <button onclick="sendHitDirect('merah', 1)" class="jr-hit-btn flex-1 bg-white/20 border-2 border-white/30 rounded-3xl font-black text-[12px] uppercase flex flex-col items-center justify-center shadow-lg"><i class="fas fa-hand-fist text-4xl mb-2"></i>PUKULAN +1</button>
                    <button onclick="sendHitDirect('merah', 2)" class="jr-hit-btn flex-1 bg-white/20 border-2 border-white/30 rounded-3xl font-black text-[12px] uppercase flex flex-col items-center justify-center shadow-lg"><i class="fas fa-shoe-prints -rotate-90 text-4xl mb-2"></i>TENDANGAN +2</button>
