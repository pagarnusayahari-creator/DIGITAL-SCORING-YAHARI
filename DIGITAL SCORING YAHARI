                    <button onclick="sendHitDirect('biru', 2)" class="jr-hit-btn flex-1 bg-white/20 border-2 border-white/30 rounded-3xl font-black text-[12px] uppercase flex flex-col items-center justify-center shadow-lg"><i class="fas fa-shoe-prints -rotate-90 text-4xl mb-2"></i>TENDANGAN +2</button>
