<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>DISCO 02.0 - Pencak Silat Digital Scoring</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap');
        body { font-family: 'Montserrat', sans-serif; background-color: #f8fafc; color: #1e293b; margin: 0; height: 100vh; width: 100vw; overflow: hidden; }
        
        .screen { display: none; height: 100vh; width: 100vw; flex-direction: column; position: absolute; top: 0; left: 0; background: #f8fafc; }
        .screen.active { display: flex; }

        .btn-raise { transition: all 0.1s; border-bottom-width: 4px !important; position: relative; top: 0; }
        .btn-raise:active { top: 2px !important; border-bottom-width: 1px !important; transform: scale(0.98); }
        
        .btn-pressed { top: 3px !important; border-bottom-width: 0px !important; background-color: #fbbf24 !important; color: #000 !important; box-shadow: inset 0 2px 4px rgba(0,0,0,0.2) !important; border-color: #d97706 !important; }

        .btn-compact { padding: 5px 2px; font-size: 7px; font-weight: 800; border-radius: 8px; border: 1px solid #e2e8f0; background: white; display: flex; flex-direction: column; align-items: center; justify-content: center; text-transform: uppercase; line-height: 1.2; }
        
        .active-babak { background-color: #10b981 !important; color: white !important; border-color: #059669 !important; box-shadow: 0 0 15px rgba(16, 185, 129, 0.6); }
        
        .sudut-merah-bg { background-color: #ef4444; color: white; }
        .sudut-biru-bg { background-color: #3b82f6; color: white; }
        
        .leader-glow { box-shadow: 0 0 30px rgba(251, 191, 36, 0.9) !important; border: 4px solid #fbbf24 !important; z-index: 10; transform: scale(1.02); }

        .table-scoring { width: 100%; font-size: 8px; border-collapse: collapse; }
        .table-scoring th, .table-scoring td { border: 1px solid #e2e8f0; padding: 3px; text-align: center; transition: background 0.3s; }
        .cell-active { background-color: #fef08a !important; color: #000 !important; font-weight: 900; }

        .custom-scroll { overflow-y: auto; }
        .custom-scroll::-webkit-scrollbar { width: 3px; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        
        .save-notif { position: fixed; top: 20px; right: 20px; background: #10b981; color: white; padding: 15px 25px; border-radius: 15px; font-weight: bold; transform: translateX(200%); transition: 0.5s; z-index: 60000; }
        .save-notif.show { transform: translateX(0); }

        .modal-overlay { position: fixed; inset: 0; background: rgba(15, 23, 42, 0.9); z-index: 10000; display: none; align-items: center; justify-content: center; padding: 20px; backdrop-filter: blur(4px); }
        .modal-overlay.active { display: flex; }
        
        .circle-vote { width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 900; color: white; border: 4px solid rgba(255,255,255,0.3); border-bottom-width: 6px; position: relative; top: 0; transition: all 0.2s; }
        .circle-blue { background-color: #3b82f6; border-color: #2563eb; }
        .circle-red { background-color: #ef4444; border-color: #dc2626; }
        .circle-yellow { background-color: #fbbf24; border-color: #d97706; }
        .circle-none { background-color: #334155; }
        
        .circle-active { border: 5px solid white !important; box-shadow: 0 0 20px rgba(255,255,255,0.6); transform: scale(1.1); }

        .penalty-summary { font-size: 7px; font-weight: 800; background: rgba(0,0,0,0.1); padding: 2px 6px; border-radius: 4px; display: inline-block; margin-top: 4px; }
        .penalty-full { font-size: 8px; font-weight: 700; color: #fff; background: rgba(0,0,0,0.3); padding: 4px 8px; border-radius: 6px; margin-top: 5px; text-transform: uppercase; }
        
        .status-header { font-size: 8px; font-weight: 800; text-transform: uppercase; padding: 6px; border-radius: 8px; text-align: left; margin-bottom: 2px; line-height: 1.3; border: 1px solid #e2e8f0; transition: all 0.3s; }
        .status-header-active-tanding { background-color: #10b981 !important; color: white !important; border-color: #059669 !important; box-shadow: 0 0 15px rgba(16, 185, 129, 0.5); }
        .status-header-active-persiapan { background-color: #f59e0b !important; color: white !important; border-color: #d97706 !important; box-shadow: 0 0 15px rgba(245, 158, 11, 0.5); }

        .input-sekre { font-size: 7.5px; font-weight: 700; border-radius: 4px; padding: 4px; outline: none; text-transform: uppercase; width: 100%; border: 1px solid rgba(0,0,0,0.1); }

        .jr-hit-btn { transition: all 0.05s; }
        .jr-hit-btn:active { background-color: #fbbf24 !important; color: #000 !important; box-shadow: 0 0 30px #fbbf24 !important; transform: scale(0.95); }

        .op-btn { font-size: 7px; padding: 6px 8px; border-radius: 6px; font-weight: 900; text-transform: uppercase; transition: all 0.2s; border: 1px solid transparent; cursor: pointer; }
        .op-btn:active { transform: scale(0.9); }
        .btn-inactive { background: #f1f5f9; color: #94a3b8; border-color: #e2e8f0; }
        .btn-bertanding { background: #10b981 !important; color: white !important; border-color: #059669; box-shadow: 0 0 20px #10b981; animation: pulse-green 2s infinite; }
        .btn-persiapan { background: #f59e0b !important; color: white !important; border-color: #d97706; box-shadow: 0 0 20px #f59e0b; animation: pulse-orange 2s infinite; }
        .btn-selesai { background: #6366f1 !important; color: white !important; border-color: #4f46e5; box-shadow: 0 0 20px #6366f1; }

        @keyframes pulse-green { 0% { box-shadow: 0 0 5px #10b981; } 50% { box-shadow: 0 0 20px #10b981; } 100% { box-shadow: 0 0 5px #10b981; } }
        @keyframes pulse-orange { 0% { box-shadow: 0 0 5px #f59e0b; } 50% { box-shadow: 0 0 20px #f59e0b; } 100% { box-shadow: 0 0 5px #f59e0b; } }
    </style>
</head>
<body>

    <div id="save-ani" class="save-notif shadow-xl"><i class="fas fa-check-circle mr-2"></i> Data Tersimpan!</div>

    <!-- MODAL DISKUALIFIKASI -->
    <div id="modal-diskualifikasi" class="modal-overlay">
        <div class="bg-white rounded-[2.5rem] p-8 w-full max-w-sm text-center shadow-2xl">
            <p class="font-black text-sm uppercase mb-8">Peserta yang didiskualifikasi adalah:</p>
            <div class="grid grid-cols-2 gap-4">
                <button onclick="executeDis('biru')" class="sudut-biru-bg py-8 rounded-3xl font-black uppercase text-xs">SUDUT BIRU</button>
                <button onclick="executeDis('merah')" class="sudut-merah-bg py-8 rounded-3xl font-black uppercase text-xs">SUDUT MERAH</button>
            </div>
            <button onclick="closeModal('modal-diskualifikasi')" class="mt-8 text-[10px] font-black text-slate-400">Batal</button>
        </div>
    </div>

    <!-- MODAL VAR RESULT (DEWAN) -->
    <div id="modal-dw-var-result" class="modal-overlay">
        <div class="bg-slate-900 rounded-[3rem] p-10 w-full max-w-md text-center shadow-2xl">
            <h2 class="text-white font-black text-2xl uppercase italic mb-10">Keputusan Juri</h2>
            <div class="flex justify-around items-center mb-12">
                <div class="flex flex-col items-center gap-3"><div id="dw-vote-1" class="circle-vote circle-none text-xl">1</div><span class="text-white/40 font-bold text-[9px]">JURI 1</span></div>
                <div class="flex flex-col items-center gap-3"><div id="dw-vote-2" class="circle-vote circle-none text-xl">2</div><span class="text-white/40 font-bold text-[9px]">JURI 2</span></div>
                <div class="flex flex-col items-center gap-3"><div id="dw-vote-3" class="circle-vote circle-none text-xl">3</div><span class="text-white/40 font-bold text-[9px]">JURI 3</span></div>
            </div>
            <button onclick="closeVAR()" class="w-full bg-emerald-500 text-white py-6 rounded-3xl font-black uppercase text-sm">A C C E P T</button>
        </div>
    </div>

    <!-- MODAL VAR TYPE SELECTION (DEWAN) -->
    <div id="modal-var-type" class="modal-overlay">
        <div class="bg-white rounded-[2.5rem] p-8 w-full max-w-sm text-center shadow-2xl">
            <h3 class="font-black text-blue-600 italic text-xl mb-2">V A R</h3>
            <p class="font-bold text-slate-400 text-[10px] mb-8">VERIFIKASI YANG DIBUTUHKAN?</p>
            <div class="grid grid-cols-1 gap-4">
                <button onclick="startVAR('JATUHAN')" class="bg-slate-800 text-white py-6 rounded-2xl font-black uppercase text-xs">JATUHAN</button>
                <button onclick="startVAR('PELANGGARAN')" class="bg-slate-800 text-white py-6 rounded-2xl font-black uppercase text-xs">PELANGGARAN</button>
            </div>
            <button onclick="closeModal('modal-var-type')" class="mt-6 text-[10px] font-black text-slate-400">Batal</button>
        </div>
    </div>

    <!-- MAIN MENU -->
    <div id="screen-landing" class="screen active p-8 justify-center items-center text-center">
        <div class="mb-10">
            <h1 class="text-3xl font-black uppercase leading-tight"><span class="text-emerald-500">Pencak Silat</span><br>Digital Scoring</h1>
            <div class="h-1 w-20 bg-red-500 mx-auto mt-4 rounded-full"></div>
        </div>
        <div class="grid grid-cols-2 gap-4 w-full max-w-sm">
            <button onclick="changeScreen('dewan')" class="bg-white p-5 rounded-[2rem] shadow-sm border-b-4 border-emerald-500 font-black text-[10px] uppercase italic"><i class="fas fa-user-tie mb-2 block text-2xl text-emerald-500"></i>Dewan</button>
            <button onclick="changeScreen('juri-select')" class="bg-white p-5 rounded-[2rem] shadow-sm border-b-4 border-blue-500 font-black text-[10px] uppercase italic"><i class="fas fa-users mb-2 block text-2xl text-blue-500"></i>Juri</button>
            <button onclick="changeScreen('sekretaris')" class="bg-white p-5 rounded-[2rem] shadow-sm border-b-4 border-purple-500 font-black text-[10px] uppercase italic"><i class="fas fa-file-signature mb-2 block text-2xl text-purple-500"></i>Sekretaris</button>
            <button onclick="changeScreen('operator')" class="bg-white p-5 rounded-[2rem] shadow-sm border-b-4 border-indigo-500 font-black text-[10px] uppercase italic"><i class="fas fa-cogs mb-2 block text-2xl text-indigo-500"></i>Operator</button>
            <button onclick="changeScreen('jadwal')" class="bg-white p-5 rounded-[2rem] shadow-sm border-b-4 border-orange-500 font-black text-[10px] uppercase italic"><i class="fas fa-calendar-alt mb-2 block text-2xl text-orange-500"></i>Jadwal</button>
            <button onclick="changeScreen('monitor')" class="bg-white p-5 rounded-[2rem] shadow-sm border-b-4 border-yellow-500 font-black text-[10px] uppercase italic"><i class="fas fa-desktop mb-2 block text-2xl text-yellow-500"></i>Monitor</button>
        </div>
        <button onclick="resetSystem()" class="mt-8 text-red-500 font-black uppercase text-[9px] border border-red-500 px-4 py-2 rounded-full active:bg-red-500 active:text-white transition-all"><i class="fas fa-trash-alt mr-2"></i> Reset Seluruh Data</button>
    </div>

    <!-- DEWAN -->
    <div id="screen-dewan" class="screen p-2">
        <div class="bg-white p-2 rounded-xl shadow-sm mb-1 border border-slate-100">
            <div class="flex justify-between items-center mb-1">
                <button onclick="changeScreen('landing')" class="bg-orange-500 px-3 py-2 rounded-lg text-white shadow-md text-xs"><i class="fas fa-home"></i></button>
                <div class="flex-1 mx-2">
                    <button onclick="changeScreen('operator')" class="w-full bg-slate-50 border-2 border-slate-200 p-2 rounded-lg text-[10px] font-black uppercase text-slate-600 shadow-sm active:scale-95 transition-all"><i class="fas fa-list-ol mr-1"></i> Pilih Partai</button>
                </div>
                <div class="text-center">
                    <h1 id="dw-timer-disp" class="text-3xl font-black text-slate-800 leading-none">02:00</h1>
                    <p id="dw-babak-disp" class="text-[9px] font-black text-red-600 uppercase mt-0.5">BABAK 1</p>
                </div>
            </div>
            <div class="flex justify-center gap-1 mb-1">
                <button onclick="setRound(1)" id="dw-btn-b1" class="text-[8px] px-4 py-1 rounded-md border font-bold uppercase btn-raise">B 1</button>
                <button onclick="setRound(2)" id="dw-btn-b2" class="text-[8px] px-4 py-1 rounded-md border font-bold uppercase btn-raise">B 2</button>
                <button onclick="setRound(3)" id="dw-btn-b3" class="text-[8px] px-4 py-1 rounded-md border font-bold uppercase btn-raise">B 3</button>
            </div>
            <div class="grid grid-cols-5 gap-1 mb-1">
                <button onclick="timerCtrl('start')" class="btn-raise bg-emerald-500 border-emerald-700 text-white font-black text-[8px] py-1.5 rounded-md"><i class="fas fa-play mr-1"></i> START</button>
                <button onclick="timerCtrl('stop')" class="btn-raise bg-red-500 border-red-700 text-white font-black text-[8px] py-1.5 rounded-md"><i class="fas fa-stop mr-1"></i> STOP</button>
                <button onclick="timerCtrl('reset')" class="btn-raise bg-slate-500 border-slate-700 text-white font-black text-[8px] py-1.5 rounded-md"><i class="fas fa-undo mr-1"></i> RESET</button>
                <button onclick="finishMatch()" class="btn-raise bg-amber-500 border-amber-700 text-white font-black text-[8px] py-1.5 rounded-md"><i class="fas fa-flag-checkered mr-1"></i> FINISH</button>
                <button id="btn-next-dewan" onclick="nextMatch()" class="btn-raise bg-purple-600 border-purple-800 text-white font-black text-[8px] py-1.5 rounded-md">NEXT <i class="fas fa-step-forward ml-1"></i></button>
            </div>
            <div class="grid grid-cols-2 gap-1">
                <button onclick="openModal('modal-diskualifikasi')" class="btn-raise bg-slate-900 text-white font-black text-[8px] py-2 rounded-md uppercase"><i class="fas fa-user-slash mr-1"></i> Diskualifikasi</button>
                <button onclick="openModal('modal-var-type')" class="btn-raise bg-blue-900 text-white font-black text-[8px] py-2 rounded-md uppercase italic"><i class="fas fa-tv mr-1"></i> V A R</button>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-1 mb-1">
            <div id="dw-header-tanding" class="status-header bg-emerald-50 text-slate-700">
                <div class="text-[6px] text-emerald-600 font-black uppercase">Sedang Bertanding:</div>
                <div id="cur-match-detail" class="text-[8px] font-bold leading-tight">---</div>
            </div>
            <div id="dw-header-persiapan" class="status-header bg-amber-50 text-slate-700">
                <div class="text-[6px] text-amber-600 font-black uppercase">Persiapan:</div>
                <div id="pers-match-detail" class="text-[8px] font-bold leading-tight">---</div>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-2 mb-1">
            <div id="dw-box-b" class="sudut-biru-bg p-2 rounded-xl text-center flex flex-col justify-center min-h-[105px] border-b-4 border-blue-800 shadow-md transition-all">
                <p id="dw-b-nama" class="text-[10px] font-black uppercase truncate">---</p>
                <p id="dw-b-kont" class="text-[7px] font-bold opacity-80 uppercase truncate">---</p>
                <h2 id="dw-total-b" class="text-5xl font-black leading-none my-1">0</h2>
                <div id="dw-pen-sum-b" class="penalty-summary text-blue-100">B:0 | T:0 | P:0</div>
            </div>
            <div id="dw-box-m" class="sudut-merah-bg p-2 rounded-xl text-center flex flex-col justify-center min-h-[105px] border-b-4 border-red-800 shadow-md transition-all">
                <p id="dw-m-nama" class="text-[10px] font-black uppercase truncate">---</p>
                <p id="dw-m-kont" class="text-[7px] font-bold opacity-80 uppercase truncate">---</p>
                <h2 id="dw-total-m" class="text-5xl font-black leading-none my-1">0</h2>
                <div id="dw-pen-sum-m" class="penalty-summary text-red-100">B:0 | T:0 | P:0</div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow-sm overflow-hidden mb-2 border border-slate-200">
            <table class="table-scoring">
                <thead class="bg-slate-100">
                    <tr class="text-[6px]"><th rowspan="2" style="width:25%">PESILAT</th><th colspan="3">JURI 1</th><th colspan="3">JURI 2</th><th colspan="3">JURI 3</th><th rowspan="2">TOT</th></tr>
                    <tr class="text-[5px]"><th>B1</th><th>B2</th><th>B3</th><th>B1</th><th>B2</th><th>B3</th><th>B1</th><th>B2</th><th>B3</th></tr>
                </thead>
                <tbody id="dw-rt-table"></tbody>
            </table>
        </div>

        <div id="dw-controls-area" class="grid grid-cols-2 gap-3 flex-1 overflow-y-auto custom-scroll pb-2">
            <div class="grid grid-cols-2 gap-1.5 h-fit">
                <button onclick="applyPenalty('biru','binaan1')" id="b-binaan1" class="btn-compact btn-raise border-blue-200"><i class="fas fa-hand-point-left text-blue-600 mb-1"></i>Binaan 1</button>
                <button onclick="applyPenalty('biru','binaan2')" id="b-binaan2" class="btn-compact btn-raise border-blue-200"><i class="fas fa-hand-peace rotate-90 text-blue-600 mb-1"></i>Binaan 2</button>
                <button onclick="applyPenalty('biru','teguran1')" id="b-teguran1" class="btn-compact btn-raise border-blue-200"><i class="fas fa-hand-point-up text-blue-600 mb-1"></i>Teguran 1</button>
                <button onclick="applyPenalty('biru','teguran2')" id="b-teguran2" class="btn-compact btn-raise border-blue-200"><i class="fas fa-hand-peace text-blue-600 mb-1"></i>Teguran 2</button>
                <button onclick="applyPenalty('biru','peringatan1')" id="b-peringatan1" class="btn-compact btn-raise border-blue-200"><i class="fas fa-exclamation-circle text-blue-600 mb-1"></i>Peringatan 1</button>
                <button onclick="applyPenalty('biru','peringatan2')" id="b-peringatan2" class="btn-compact btn-raise border-blue-200"><i class="fas fa-exclamation-triangle text-blue-600 mb-1"></i>Peringatan 2</button>
                <button onclick="addJatuhan('biru')" class="btn-raise sudut-biru-bg border-blue-800 text-[9px] font-black py-2 rounded-lg col-span-2">JATUHAN +3</button>
            </div>
            <div class="grid grid-cols-2 gap-1.5 h-fit">
                <button onclick="applyPenalty('merah','binaan1')" id="m-binaan1" class="btn-compact btn-raise border-red-200"><i class="fas fa-hand-point-right text-red-600 mb-1"></i>Binaan 1</button>
                <button onclick="applyPenalty('merah','binaan2')" id="m-binaan2" class="btn-compact btn-raise border-red-200"><i class="fas fa-hand-peace rotate-90 text-red-600 mb-1"></i>Binaan 2</button>
                <button onclick="applyPenalty('merah','teguran1')" id="m-teguran1" class="btn-compact btn-raise border-red-200"><i class="fas fa-hand-point-up text-red-600 mb-1"></i>Teguran 1</button>
                <button onclick="applyPenalty('merah','teguran2')" id="m-teguran2" class="btn-compact btn-raise border-red-200"><i class="fas fa-hand-peace text-red-600 mb-1"></i>Teguran 2</button>
                <button onclick="applyPenalty('merah','peringatan1')" id="m-peringatan1" class="btn-compact btn-raise border-red-200"><i class="fas fa-exclamation-circle text-red-600 mb-1"></i>Peringatan 1</button>
                <button onclick="applyPenalty('merah','peringatan2')" id="m-peringatan2" class="btn-compact btn-raise border-red-200"><i class="fas fa-exclamation-triangle text-red-600 mb-1"></i>Peringatan 2</button>
                <button onclick="addJatuhan('merah')" class="btn-raise sudut-merah-bg border-red-800 text-[9px] font-black py-2 rounded-lg col-span-2">JATUHAN +3</button>
            </div>
        </div>
    </div>

    <!-- SEKRETARIS -->
    <div id="screen-sekretaris" class="screen">
        <div class="p-4 bg-white shadow-sm flex justify-between items-center">
            <button onclick="changeScreen('landing')" class="text-gray-400"><i class="fas fa-arrow-left"></i></button>
            <h2 class="text-xs font-black uppercase">Input Sekretaris</h2>
            <button onclick="saveSekreData()" class="text-emerald-600 font-black text-[10px]">SIMPAN</button>
        </div>
        <div class="flex-1 overflow-y-auto p-2 bg-slate-50 custom-scroll">
            <div id="sekre-form-container" class="space-y-3 pb-20"></div>
        </div>
        <div class="bg-white p-3 border-t flex justify-between items-center">
            <button onclick="changeSekrePage(-1)" class="bg-slate-100 px-4 py-2 rounded-lg text-[9px] font-black">PREV</button>
            <span id="sekre-page-info" class="text-[9px] font-bold">Hal 1 / 10</span>
            <button onclick="changeSekrePage(1)" class="bg-slate-100 px-4 py-2 rounded-lg text-[9px] font-black">NEXT</button>
        </div>
    </div>

    <!-- OPERATOR -->
    <div id="screen-operator" class="screen bg-slate-50">
        <div class="p-4 bg-white shadow-sm flex justify-between items-center">
            <div class="flex gap-2">
                <button onclick="changeScreen('landing')" class="text-slate-400 text-sm p-1"><i class="fas fa-arrow-left"></i></button>
                <button onclick="changeScreen('dewan')" class="bg-emerald-500 text-white px-3 py-1.5 rounded-lg font-black text-[9px] uppercase italic shadow-sm active:scale-95">Ke Dewan</button>
            </div>
            <h2 class="text-xs font-black uppercase italic text-indigo-600">Operator Panel</h2>
            <button onclick="exportCSV()" class="bg-indigo-600 text-white px-3 py-1.5 rounded-lg font-black text-[9px] uppercase italic shadow-sm"><i class="fas fa-file-export mr-1"></i> Export Data</button>
        </div>
        <div class="flex-1 overflow-x-auto p-2">
            <table class="w-full text-[7.5px] border-collapse bg-white shadow-sm rounded-lg overflow-hidden">
                <thead class="bg-indigo-600 text-white">
                    <tr><th class="border p-2">No</th><th class="border p-2">Partai</th><th class="border p-2">Nama Peserta</th><th class="border p-2">Status</th><th class="border p-2">Pemenang</th><th class="border p-2">Aksi</th></tr>
                </thead>
                <tbody id="operator-table-body" class="text-center font-bold"></tbody>
            </table>
        </div>
    </div>

    <!-- JADWAL -->
    <div id="screen-jadwal" class="screen bg-slate-50">
        <div class="p-4 bg-white shadow-sm flex justify-between items-center">
            <button onclick="changeScreen('landing')" class="text-gray-400"><i class="fas fa-arrow-left"></i></button>
